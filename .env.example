# ═══════════════════════════════════════════════
#  MangaServer — Configuración
#  Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════

# Nombre del usuario administrador principal
ADMIN_USERNAME=tu_usuario_aqui

# Contraseña para entrar al servidor
ADMIN_PASSWORD=tu_contrasena_aqui

# Clave secreta para los tokens JWT
# Ponle cualquier texto largo y aleatorio — mientras más largo mejor
JWT_SECRET=cambia_esto_por_algo_muy_largo_y_aleatorio_1234567890

# Puerto del servidor (por defecto 3000)
PORT=3000

# Ruta principal a tu carpeta de mangas
# Ejemplo Windows: D:\Mis Mangas
# Ejemplo relativo: ./main
MANGA_PATH=./main

# Segunda carpeta de mangas (opcional)
# Descomenta y completa si tienes los mangas en dos carpetas distintas
# MANGA_PATH_2=D:\Mis Mangas 2
