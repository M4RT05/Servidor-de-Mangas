# Copia este archivo como .env y completa los valores

# Usuario para entrar al servidor (la que tú elijas)
USERNAME=tu_usuario_aqui
PASSWORD=tu_contrasena_aqui

# Clave secreta para los tokens JWT (ponle cualquier texto largo y aleatorio)
JWT_SECRET=cambia_esto_por_algo_muy_largo_y_aleatorio_1234567890

# Puerto del servidor
PORT=3000

# Ruta a la carpeta con tus mangas (relativa a la raíz del proyecto)
MANGA_PATH=./main
